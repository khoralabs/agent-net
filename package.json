{
  "name": "@khoralabs/agent-net-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "vendor/libs/packages/*/**"
  ],
  "overrides": {
    "@khoralabs/memories-node": "0.5.0",
    "@khoralabs/memories-service": "0.5.0",
    "@khoralabs/memories-agents": "0.5.0",
    "@khoralabs/memories-react-graph": "0.5.0",
    "@khoralabs/memories-spec": "0.5.0",
    "@libsql/client": "0.17.4"
  },
  "scripts": {
    "typecheck": "bun run --filter '@khoralabs/agent-net' typecheck && bun run --filter '@khoralabs/agent-net-swarm' typecheck && bun run --filter '@khoralabs/agent-net-reference' typecheck",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "agent:dev": "bun run --filter @khoralabs/agent-net-reference agent:dev",
    "agent:setup": "bun run --filter @khoralabs/agent-net-reference agent:setup",
    "agent:test": "bun run --filter @khoralabs/agent-net test",
    "test:with-sqlite": "bash scripts/test-with-homebrew-sqlite.sh",
    "reference:start": "bun run --filter @khoralabs/agent-net-reference start",
    "swarm": "bun run --filter @khoralabs/agent-net-reference swarm",
    "swarm:setup": "bun run --filter @khoralabs/agent-net-reference agent:setup",
    "swarm:events": "bun run --filter @khoralabs/agent-net-reference events",
    "swarm:test": "bash scripts/test-with-homebrew-sqlite.sh packages/swarm/src packages/harness/src",
    "submodules:init": "git submodule update --init --recursive",
    "submodules:update": "git submodule update --remote --merge vendor/libs && bun install",
    "prepare": "husky"
  },
  "dependencies": {
    "@khoralabs/memories-node": "^0.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "typescript": "^5"
  }
}
