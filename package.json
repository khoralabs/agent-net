{
  "name": "@khoralabs/agent-net",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./swarm": "./src/swarm/index.ts",
    "./network": "./src/network/index.ts"
  },
  "workspaces": [
    "vendor/libs/packages/*/**",
    "vendor/chat/core",
    "vendor/chat/persistence",
    "vendor/chat/sqlite",
    "vendor/relay/packages/*/**",
    "vendor/memories/packages/*/**",
    "vendor/memories/packages/memories-service/*/**"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "agent:dev": "nitro dev",
    "agent:setup": "workflow-turso-setup",
    "agent:test": "bun test src/agent",
    "swarm": "bun run src/swarm/run.ts",
    "swarm:setup": "workflow-turso-setup",
    "swarm:events": "bun run src/swarm/events-cli.ts",
    "swarm:test": "bun test src/swarm src/agent/tools/chat src/observability src/network",
    "submodules:init": "git submodule update --init --recursive",
    "submodules:update": "git submodule update --remote --merge vendor/memories vendor/relay vendor/chat vendor/libs && bun install"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.3",
    "@khoralabs/agent-capabilities": "^0.2.0",
    "@khoralabs/agent-capabilities-ai-sdk": "^0.2.0",
    "@khoralabs/agent-capabilities-otel": "^0.2.0",
    "@khoralabs/did-key-identity": "^0.1.0",
    "@khoralabs/chat-core": "workspace:*",
    "@khoralabs/chat-persistence": "workspace:*",
    "@khoralabs/chat-persistence-sqlite": "workspace:*",
    "@khoralabs/khora-client": "^0.1.0",
    "@khoralabs/vellum-client": "^0.1.0",
    "@khoralabs/memories-core": "workspace:*",
    "@khoralabs/memories-ontologies": "workspace:*",
    "@khoralabs/memories-persistence-core": "workspace:*",
    "@khoralabs/memories-service-auth": "workspace:*",
    "@khoralabs/memories-service-client": "workspace:*",
    "@khoralabs/memories-service-http": "workspace:*",
    "@khoralabs/memories-service-storage-core": "workspace:*",
    "@khoralabs/memories-service-storage-sqlite": "workspace:*",
    "@khoralabs/observability": "workspace:*",
    "@khoralabs/relay-client": "workspace:*",
    "@khoralabs/relay-crypto": "workspace:*",
    "@khoralabs/relay-server-http": "workspace:*",
    "@libsql/client": "^0.14.0",
    "@noble/ed25519": "^3.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@workflow-worlds/turso": "^0.2.2",
    "ai": "^7.0.9",
    "nitro": "^3.0.0",
    "pino": "^9.6.0",
    "unstorage": "^1.17.5",
    "workflow": "^4.5.0",
    "zod": "^4"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
